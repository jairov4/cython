PYTHON setup.py build_ext --inplace
PYTHON -c "import b; import a"

######## setup.py ########

from Cython.Build.Dependencies import cythonize
import Cython.Compiler.Options
Cython.Compiler.Options.cimport_from_pyx = True

from distutils.core import setup

setup(
  ext_modules = cythonize("*.pyx"),
)

######## a.pyx ########
from b import B
from b cimport B  # <--- cimport allows optimization of direct method calls cross module
from cython import ccall

@ccall
def main():
    B().m()  # <--- direct call to B.m() should be optimized cross module

######## b.pyx ########

from cython import final, cclass, ccall

@cclass
class A:
    @ccall
    def m(self):
        pass

@final  # <--- final class allows optimization of direct method calls cross module
@cclass
class B(A):
    @ccall
    def m(self):
        pass
